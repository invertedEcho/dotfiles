{
    "layer": "top",
    "height": 25,
    "modules-left": ["wlr/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["pulseaudio", "network", "backlight", "battery", "clock", "cpu", "memory"],
    "wlr/workspaces": {
        "active-only": false,
        "on-click": "activate",
        "disable-scroll": true,
        "format": "{icon}",
        "format-icons": {
            "1": "1 ΌτΕ",
            "2": "2 ≤░Ι╣",
            "3": "3 ΌηΧ",
            "4": "4 ΌεΓ",
            "5": "5 ≤░βψ",
