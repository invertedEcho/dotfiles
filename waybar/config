{
    "layer": "top",
    "margin-left": 0,
    "margin-right": 0,
    "margin-top": 0,
    "spacing": 1,

    "modules-left": ["custom/wofi", "hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["battery", "pulseaudio", "network", "tray"],

    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "1": "1 ΌτΕ",
            "2": "2 ≤░Ι╣",
	    "3": "3 ≤▒ηΒ",
	    "4": "4 ≤▒πΝ",
	    "5": "5 ΎΑΒ",
            "6": "6",
            "7": "7",
            "8": "8",
            "9": "9",
            // "urgent": "ΎΗΤ",
            // "active": "ΎΕΣ",
            // "default": "ΎΤς"
         },
    },
    "tray": {
        "icon-size": 18,
        "spacing": 5,
        "show-passive-items": true,
    },
    "clock": {
        "interval": 60,
        "format": "ΎΒ│  {:%a %b %d  %I:%M %p}", // %b %d %Y  ΎΡ║--Date formatting
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
   "battery": {
        "interval": 60,
	"states": {
	  "warning": 30,
	  "critical": 15
	},
        "format": "{capacity}% ΎΚΑ",
    },
    "network": {
        "format-wifi": "ΎΘτ :{ipaddr}",
        "format-ethernet": "≤░ΙΑ {ipaddr}/{cidr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "Disconnected έγι",
	"on-click": "iwgtk"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% ≤░Γψ",
        "format-bluetooth-muted": "≤░ΨΒ {icon} ≤░Γψ",
        "format-muted": "≤░ΨΒ {format_source}",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "≤░ΜΜ",
            "hands-free": "≤▒κΤ",
            "headset": "≤░ΜΟ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/wofi": {
      "format": "{icon}",
      "format-icons": "≤░μΘ",
      "exec-on-event": "true",
      "on-click": "wofi --show=drun",
    },
    "custom/sepp": {
        "format": "|"
    },
}
