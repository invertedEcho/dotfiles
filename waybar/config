{
    // -------------------------------------------------------------------------
    // Global configuration
    // -------------------------------------------------------------------------

    "layer": "top",

    "position": "top",

    // If height property would be not present, it'd be calculated dynamically
    "height": 30,

    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "network",
        "memory",
        "cpu",
	"backlight",
        "battery",
	"pulseaudio",
        "tray",
        "clock#date",
        "clock#time"
    ],


    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "1": "1 code",
            "2": "2 www",
	    "3": "3 term",
	    "4": "4 notes",
	    "5": "5 chat",
            "6": "6 music",
            "7": "7",
            "8": "8",
            "9": "9 minimized",
            // "urgent": "п†’",
            // "active": "п„‘",
            // "default": "п’Є"
         },
    },
    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        // Connected to AC
        "format": "пѓ§  {icon}  {capacity}%", // Icon: bolt
        // Not connected to AC
        "format-discharging": "{icon}  {capacity}%",
        "format-icons": [
            "п‰„", // Icon: battery-full
            "п‰ѓ", // Icon: battery-three-quarters
            "п‰‚", // Icon: battery-half
            "п‰Ѓ", // Icon: battery-quarter
            "п‰Ђ"  // Icon: battery-empty
        ],
        "tooltip": true
    },

    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "tooltip": false
    },

    "clock#date": {
      "interval": 10,
      "format": "пЃі  {:%e %b %Y}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
	"mode"          : "year",
	"mode-mon-col"  : 3,
	"weeks-pos"     : "right",
	"on-scroll"     : 1,
	"on-click-right": "mode",
	"format": {
		"months":     "<span color='#ffead3'><b>{}</b></span>",
		"days":       "<span color='#ecc6d9'><b>{}</b></span>",
		"weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
		"weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
		"today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
	}
      }
    },

    "cpu": {
        "interval": 5,
        "format": "п‹›  {usage}%",
        "states": {
          "warning": 70,
          "critical": 90
        }
    },

    "memory": {
        "interval": 5,
        "format": "п‡Ђ  {}%",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "backlight": {
	"format": "{icon} {percent}% ",
	"format-icons": ["у°ѓ "]
    },

    "network": {
        "interval": 5,
        "format-wifi": "п‡«  {essid} ({signalStrength}%)", // Icon: wifi
        "format-ethernet": "у°€Ђ  {ifname}: {ipaddr}/{cidr}", // Icon: ethernet
        "format-disconnected": "вљ   Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}",
	"on-click": "iwgtk"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">пЊћ  {}</span>", // Icon: expand-arrows-alt
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 120
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% у°‚Ї",
        "format-bluetooth-muted": "у°–Ѓ {icon} у°‚Ї",
        "format-muted": "у°–Ѓ 0%",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "у°‹‹",
            "hands-free": "у±Ў’",
            "headset": "у°‹Ћ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol"
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10
    }

}
